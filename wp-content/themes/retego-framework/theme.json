{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 3,
  "settings": {
    "appearanceTools": true,
    "useRootPaddingAwareAlignments": true,
    "layout": {
      "contentSize": "760px",
      "wideSize": "1280px"
    },
    "spacing": {
      "padding": true,
      "margin": true,
      "units": ["px", "em", "rem", "vh", "vw", "%"],
      "spacingScale": {
        "steps": 0,
        "operator": "*",
        "increment": 8,
        "mediumStep": 8,
        "unit": "px"
      },
      "customSpacingSize": true,
      "blockGap": true,
      "defaultSpacingSizes": false
    },
    "border": {
      "color": true,
      "radius": true,
      "style": true,
      "width": true
    },
    "color": {
      "background": true,
      "defaultDuotone": false,
      "defaultGradients": false,
      "defaultPalette": false,
      "duotone": [
        {
          "name": "Primary Blue",
          "colors": ["#0B5FFF", "#2563EB"],
          "slug": "primary-blue"
        }
      ],
      "gradients": [
        {
          "name": "Primary to Accent",
          "gradient": "linear-gradient(135deg, #0B5FFF 0%, #2563EB 100%)",
          "slug": "primary-accent"
        }
      ],
      "palette": [
        {
          "name": "Primary",
          "slug": "primary",
          "color": "#0B5FFF"
        },
        {
          "name": "Secondary",
          "slug": "secondary",
          "color": "#111827"
        },
        {
          "name": "Background",
          "slug": "background",
          "color": "#FFFFFF"
        },
        {
          "name": "Light Background",
          "slug": "light-background",
          "color": "#F8FAFC"
        },
        {
          "name": "Accent",
          "slug": "accent",
          "color": "#2563EB"
        }
      ],
      "text": true
    },
    "typography": {
      "defaultFontSizes": false,
      "fluid": true,
      "fontFamilies": [
        {
          "fontFace": [
            {
              "fontFamily": "Inter",
              "fontStyle": "normal",
              "fontWeight": "100 900",
              "src": ["file:./assets/fonts/Inter-Variable.woff2"]
            }
          ],
          "name": "Inter",
          "slug": "inter"
        }
      ],
      "fontSizes": [
        {
          "name": "Small",
          "slug": "small",
          "size": "0.875rem"
        },
        {
          "name": "Base",
          "slug": "base",
          "size": "1rem"
        },
        {
          "name": "Large",
          "slug": "large",
          "size": "1.25rem"
        },
        {
          "name": "XL",
          "slug": "xl",
          "size": "1.5rem"
        },
        {
          "name": "XXL",
          "slug": "xxl",
          "size": "2rem"
        },
        {
          "name": "3XL",
          "slug": "3xl",
          "size": "2.75rem"
        }
      ],
      "fontStyle": true,
      "fontWeight": true,
      "letterSpacing": true,
      "lineHeight": true,
      "textAlign": true,
      "textDecoration": true,
      "textTransform": true
    },
    "custom": {
      "spacing": {
        "section": "64px",
        "sectionMobile": "32px"
      }
    }
  },
  "styles": {
    "color": {
      "background": "var(--wp--preset--color--background)",
      "text": "var(--wp--preset--color--secondary)"
    },
    "elements": {
      "h1": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--inter)",
          "fontWeight": "700",
          "lineHeight": "1.1"
        }
      },
      "h2": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--inter)",
          "fontWeight": "700",
          "lineHeight": "1.2"
        }
      },
      "h3": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--inter)",
          "fontWeight": "600",
          "lineHeight": "1.3"
        }
      },
      "p": {
        "typography": {
          "fontFamily": "var(--wp--preset--font-family--inter)",
          "lineHeight": "1.7"
        }
      },
      "link": {
        "color": {
          "text": "var(--wp--preset--color--primary)"
        },
        "typography": {
          "textDecoration": "none"
        }
      }
    },
    "spacing": {
      "blockGap": "1.5rem"
    },
    "typography": {
      "fontFamily": "var(--wp--preset--font-family--inter)",
      "fontSize": "var(--wp--preset--font-size--base)"
    }
  }
}
